# Chrome Enterprise Premium MCP Server
#
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# The server loads .env automatically on startup. All variables are optional.
# The server runs in stdio mode with ADC by default.


# Authentication
#
# In stdio mode (default), the server authenticates to Google APIs using
# Application Default Credentials (ADC). Set these up with:
#
#   gcloud auth application-default login --scopes="<scopes>"
#   gcloud auth application-default set-quota-project YOUR_PROJECT_ID
#
# See README.md for the full scopes list.

# GCP project used for API enablement and quotas. Required if not set via gcloud CLI.
# Find your project ID at: https://console.cloud.google.com/cloud-resource-manager
# GOOGLE_CLOUD_QUOTA_PROJECT=your-project-id


# Transport
#
# The server defaults to stdio transport (for local MCP clients like Claude
# Desktop). Set GCP_STDIO=false to start an HTTP server instead. HTTP mode
# is unauthenticated; bind to a trusted interface only.

GCP_STDIO=true
# PORT=3000


# Evaluations
#
# The eval runner uses Gemini as an LLM judge. Get an API key at:
#   https://aistudio.google.com/apikey

# GEMINI_API_KEY=your-gemini-api-key


# Feature Flags
#
# Experimental features are gated behind EXPERIMENT_ prefixed variables.
# All are disabled by default.

# Enable delete tools (delete DLP rules and detectors)
# EXPERIMENT_DELETE_TOOL_ENABLED=true
